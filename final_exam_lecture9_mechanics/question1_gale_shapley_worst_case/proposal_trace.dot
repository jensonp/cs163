digraph G {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad=0.35,
    nodesep=0.3,
    ranksep=0.45,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Question 1: proposal trace with alphabetical free-proposer order"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=16,
    penwidth=1.6,
    margin="0.15,0.08"
  ];

  edge [color="#475569", penwidth=1.6, arrowsize=0.8];

  n1 [label="1. P1 -> R1\nR1 holds P1", fillcolor="#dbeafe", color="#2563eb"];
  n2 [label="2. P2 -> R1\nR1 rejects P2", fillcolor="#fee2e2", color="#dc2626"];
  n3 [label="3. P3 -> R2\nR2 holds P3", fillcolor="#dbeafe", color="#2563eb"];
  n4 [label="4. P2 -> R2\nR2 prefers P2, rejects P3", fillcolor="#fee2e2", color="#dc2626"];
  n5 [label="5. P3 -> R1\nR1 prefers P3, rejects P1", fillcolor="#fee2e2", color="#dc2626"];
  n6 [label="6. P1 -> R2\nR2 prefers P1, rejects P2", fillcolor="#fee2e2", color="#dc2626"];
  n7 [label="7. P2 -> R3\nR3 holds P2\nFinal matching: (P3,R1), (P1,R2), (P2,R3)", fillcolor="#dcfce7", color="#16a34a"];

  n1 -> n2 -> n3 -> n4 -> n5 -> n6 -> n7;
}
