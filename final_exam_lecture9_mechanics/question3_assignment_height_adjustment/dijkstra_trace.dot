digraph G {
  graph [
    layout=neato,
    overlap=false,
    splines=true,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Question 3: one Dijkstra iteration from the super-source\nTie-break alphabetically: A is explored before B."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=0.9,
    height=0.9,
    style=filled,
    fontname="Helvetica",
    fontsize=17,
    penwidth=2.0,
    pin=true
  ];

  edge [penwidth=2.0, color="#cbd5e1", fontname="Helvetica", fontsize=15, arrowsize=0.8];

  s [label="s\ndist 0", fillcolor="#fef3c7", color="#d97706", pos="0,120!"];
  A [label="A\ndist 0", fillcolor="#dbeafe", color="#2563eb", pos="150,220!"];
  B [label="B\ndist 0", fillcolor="#dbeafe", color="#2563eb", pos="150,20!"];
  X [label="X\ndist 5", fillcolor="#ffedd5", color="#ea580c", pos="350,220!"];
  Y [label="Y\ndist 2", fillcolor="#ffedd5", color="#ea580c", pos="350,20!"];

  s -> A [label="0", color="#16a34a", fontcolor="#16a34a", penwidth=3.6, style=dashed];
  s -> B [label="0", style=dashed];

  A -> X [label="5"];
  A -> Y [label="2", color="#16a34a", fontcolor="#16a34a", penwidth=3.6];
  B -> X [label="6"];
  B -> Y [label="4"];
}
