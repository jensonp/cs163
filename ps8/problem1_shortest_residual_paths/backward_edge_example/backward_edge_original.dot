digraph G {
  graph [
    layout=neato,
    overlap=false,
    splines=true,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Backward-edge example: the original flow network\nAll capacities are 1."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=0.76,
    height=0.76,
    style=filled,
    fillcolor="#f8fafc",
    color="#0f172a",
    penwidth=2.0,
    fontname="Helvetica",
    fontsize=18,
    pin=true
  ];

  edge [
    color="#475569",
    penwidth=2.4,
    arrowsize=0.9,
    fontname="Helvetica",
    fontsize=16
  ];

  s [label="s", pos="0,110!"];
  a [label="a", pos="170,220!"];
  b [label="b", pos="170,0!"];
  t [label="t", pos="340,110!"];

  s -> a [label="1"];
  s -> b [label="1"];
  a -> b [label="1"];
  a -> t [label="1"];
  b -> t [label="1"];
}
