graph G {
  graph [
    layout=neato,
    overlap=false,
    splines=true,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Lesson 1: a cycle in a planar graph separates inside from outside\nAny path from d to e must pass through the separator vertices a, b, or c."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=0.78,
    height=0.78,
    style=filled,
    fontname="Helvetica",
    fontsize=18,
    penwidth=2.0,
    pin=true
  ];

  edge [penwidth=2.2, color="#64748b"];

  a [label="a", fillcolor="#fed7aa", color="#ea580c", pos="0,0!"];
  b [label="b", fillcolor="#fed7aa", color="#ea580c", pos="140,220!"];
  c [label="c", fillcolor="#fed7aa", color="#ea580c", pos="280,0!"];
  d [label="d", fillcolor="#dbeafe", color="#2563eb", pos="140,85!"];
  e [label="e", fillcolor="#dcfce7", color="#16a34a", pos="140,340!"];

  a -- b [color="#f59e0b", penwidth=3.6];
  b -- c [color="#f59e0b", penwidth=3.6];
  c -- a [color="#f59e0b", penwidth=3.6];

  d -- a;
  d -- b;
  d -- c;
  e -- a;
  e -- b;
  e -- c;

  inside_label [shape=plain, width=0, height=0, margin=0, style="", label="inside", pos="140,136!"];
  outside_label [shape=plain, width=0, height=0, margin=0, style="", label="outside", pos="140,405!"];
  jct_note [shape=plain, width=0, height=0, margin=0, style="", label="Jordan curve idea: the orange cycle is a boundary.", pos="140,-78!"];
}
