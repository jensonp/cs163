graph G {
  graph [
    layout=neato,
    overlap=false,
    splines=false,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Step 3: build the compatibility/conflict graph\nA vertex is a flap; an edge means the two flaps cannot go on the same side."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=0.95,
    height=0.95,
    style=filled,
    penwidth=2.0,
    fontname="Helvetica",
    fontsize=18,
    pin=true
  ];

  edge [penwidth=2.5, color="#334155"];

  F1 [label="F1\n(v1,v3)", fillcolor="#fee2e2", color="#dc2626", pos="0,0!"];
  F2 [label="F2\n(v2,v5)", fillcolor="#dbeafe", color="#2563eb", pos="170,130!"];
  F3 [label="F3\n(v4,v6)", fillcolor="#dcfce7", color="#16a34a", pos="340,0!"];

  F1 -- F2;
  F2 -- F3;
}
