graph G {
  graph [
    layout=neato,
    overlap=false,
    splines=true,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Tiny example: a square cycle with two flaps\nF1 = AC and F2 = BD. Their endpoints alternate, so they conflict."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=0.72,
    height=0.72,
    style=filled,
    fillcolor="#f8fafc",
    color="#0f172a",
    penwidth=2.0,
    fontname="Helvetica",
    fontsize=18,
    pin=true
  ];

  edge [penwidth=2.2, color="#475569", fontname="Helvetica", fontsize=16];

  A [label="A", pos="0,220!"];
  B [label="B", pos="220,220!"];
  C [label="C", pos="220,0!"];
  D [label="D", pos="0,0!"];

  A -- B;
  B -- C;
  C -- D;
  D -- A;

  A -- C [color="#dc2626", penwidth=3.6, fontcolor="#dc2626", label="F1"];
  B -- D [color="#2563eb", penwidth=3.6, fontcolor="#2563eb", label="F2"];
}
