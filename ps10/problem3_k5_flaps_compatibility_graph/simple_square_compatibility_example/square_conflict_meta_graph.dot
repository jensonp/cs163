graph G {
  graph [
    layout=neato,
    overlap=false,
    splines=false,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="The compatibility/conflict graph\nEach node is a flap. An edge means the two flaps cannot go on the same side."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=1.0,
    height=1.0,
    style=filled,
    penwidth=2.0,
    fontname="Helvetica",
    fontsize=18,
    pin=true
  ];

  edge [penwidth=2.6, color="#0f172a", fontname="Helvetica", fontsize=16];

  F1 [label="F1\n(AC)", fillcolor="#fee2e2", color="#dc2626", pos="0,0!"];
  F2 [label="F2\n(BD)", fillcolor="#dbeafe", color="#2563eb", pos="220,0!"];

  F1 -- F2 [label="conflict"];
}
