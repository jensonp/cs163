graph G {
  graph [
    layout=neato,
    overlap=false,
    splines=false,
    outputorder=edgesfirst,
    bgcolor="white",
    pad=0.35,
    labelloc=t,
    fontsize=20,
    fontname="Helvetica",
    label="Color the meta-graph with two colors: Inside and Outside\nBecause the graph is bipartite, the assignment succeeds."
  ];

  node [
    shape=circle,
    fixedsize=true,
    width=1.0,
    height=1.0,
    style=filled,
    penwidth=2.0,
    fontname="Helvetica",
    fontsize=18,
    pin=true
  ];

  edge [penwidth=2.6, color="#334155"];

  F1 [label="F1\ninside", fillcolor="#dcfce7", color="#16a34a", pos="0,0!"];
  F2 [label="F2\noutside", fillcolor="#ede9fe", color="#7c3aed", pos="220,0!"];

  F1 -- F2;
}
